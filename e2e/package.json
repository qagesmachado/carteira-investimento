{
  "name": "carteira-investimento-e2e",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "pretest:ui": "node ./scripts/reset-test-db.js",
    "test:ui": "playwright test --project=ui",
    "test:ui:serial": "cross-env E2E_WORKERS=1 playwright test --project=ui",
    "test:smoke": "playwright test --config=playwright.smoke.config.js",
    "test": "npm run test:ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.1",
    "cross-env": "^7.0.3",
    "typescript": "^5.6.3"
  }
}
